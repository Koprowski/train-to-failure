{
  "name": "train-to-failure",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/build.mjs",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "seed:test-user": "tsx scripts/seed-test-user.ts",
    "sync:exercise-library": "python scripts/sync_exercise_library.py --dry-run",
    "sync:exercise-library:apply": "python scripts/sync_exercise_library.py --apply",
    "sync:exercise-library:prune": "python scripts/sync_exercise_library.py --apply --remove all",
    "sync:local": "powershell -ExecutionPolicy Bypass -File scripts/sync-local.ps1",
    "sync:local:apply": "powershell -ExecutionPolicy Bypass -File scripts/sync-local.ps1 -Apply",
    "sync:local:prune": "powershell -ExecutionPolicy Bypass -File scripts/sync-local.ps1 -Apply -Remove all",
    "sync:local:full": "npm run sync:local:apply && npm run lint && npm run build",
    "sync:staging": "powershell -ExecutionPolicy Bypass -File scripts/sync-staging.ps1",
    "sync:staging:apply": "powershell -ExecutionPolicy Bypass -File scripts/sync-staging.ps1 -Apply",
    "sync:staging:prune": "powershell -ExecutionPolicy Bypass -File scripts/sync-staging.ps1 -Apply -Remove all",
    "sync:staging:full": "npm run sync:staging:apply && npm run lint && npm run build",
    "sync:production": "powershell -ExecutionPolicy Bypass -File scripts/sync-production.ps1",
    "sync:production:apply": "powershell -ExecutionPolicy Bypass -File scripts/sync-production.ps1 -Apply",
    "sync:production:prune": "powershell -ExecutionPolicy Bypass -File scripts/sync-production.ps1 -Apply -Remove all",
    "sync:production:full": "npm run sync:production:apply && npm run lint && npm run build"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "@prisma/extension-accelerate": "^3.0.1",
    "@vercel/blob": "2.3.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "prisma": "^5.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-muscle-highlighter": "^1.2.0",
    "recharts": "^3.7.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
